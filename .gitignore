# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# loose reference material dropped in the repo root while iterating
# (design docs, ad-hoc screenshots) — real assets belong in /public
/*.pdf
/Screenshot *.png
/Screenshot *.PNG
/IMG_*.PNG
/IMG_*.png

# internal reference docs (brand guidelines, design briefs) — not for public repo
/docs/reference/*.pdf
